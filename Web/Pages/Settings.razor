@page "/custom-raid-times"
@layout CustomRaidTimes.Web.Layouts.MainLayout
@using CustomRaidTimes.Web.Components

@inject ConfigService ConfigService

<MudGrid Justify="Justify.Center">
    <MudItem xs="12" sm="12" md="11" lg="10">
        <MudExpansionPanels MultiExpansion="true">

            @* General *@
            <MudExpansionPanel Text="General" Expanded="true">
                <MudStack Spacing="1" Class="pa-2">
                    <MudSwitch @bind-Value="Config.General.Enabled"
                               Label="Enabled"
                               Color="Color.Primary" />
                    <MudText Typo="Typo.body2" Class="mb-3" Style="color: var(--mud-palette-text-secondary);">
                        Enable or disable the mod entirely.
                    </MudText>

                    <MudSwitch @bind-Value="Config.General.Debug"
                               Label="Debug Logging"
                               Color="Color.Primary" />
                    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
                        Log detailed raid time and train schedule changes to the server console.
                    </MudText>
                </MudStack>
            </MudExpansionPanel>

            @* Raid Times *@
            <MudExpansionPanel Text="Raid Times" Expanded="true">
                <MudStack Spacing="1" Class="pa-2">
                    <MudSwitch @bind-Value="Config.RaidTimes.OverrideAll"
                               Label="Override All Maps"
                               Color="Color.Primary" />
                    <MudText Typo="Typo.body2" Class="mb-3" Style="color: var(--mud-palette-text-secondary);">
                        Use the global override time for all maps instead of per-map custom times.
                    </MudText>

                    <MudSwitch @bind-Value="Config.RaidTimes.OverrideScav"
                               Label="Override Scav Raid Times"
                               Color="Color.Primary" />
                    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
                        Prevent the server from reducing scav raid times. Scavs will use the full custom raid time.
                    </MudText>

                    @if (Config.RaidTimes.OverrideAll)
                    {
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.subtitle1">Global Override</MudText>
                        <TimeSettingEditor Value="Config.RaidTimes.Override" Label="Override" />
                    }
                    else
                    {
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.subtitle1">Per-Map Times</MudText>

                        <MudExpansionPanels MultiExpansion="true">
                            @foreach (var (_, (configKey, label)) in ModConfig.LocationMap)
                            {
                                if (Config.RaidTimes.CustomTimes.TryGetValue(configKey, out var setting))
                                {
                                    <MudExpansionPanel Text="@label">
                                        <TimeSettingEditor Value="setting" Label="@label" />
                                    </MudExpansionPanel>
                                }
                            }
                        </MudExpansionPanels>
                    }
                </MudStack>
            </MudExpansionPanel>

            @* Train Schedule *@
            <MudExpansionPanel Text="Train Schedule" Expanded="true">
                <MudStack Spacing="1" Class="pa-2">
                    <MudSwitch @bind-Value="Config.TrainSchedule.Auto"
                               Label="Auto Schedule"
                               Color="Color.Primary" />
                    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
                        Automatically generate train schedules that fit within the raid time. Highly recommended.
                    </MudText>

                    @if (!Config.TrainSchedule.Auto)
                    {
                        <MudDivider Class="my-2" />
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                            Manual train scheduling is advanced. If misconfigured, the train may not arrive in time to extract.
                        </MudAlert>
                        <MudNumericField @bind-Value="Config.TrainSchedule.Static.ArriveEarliestMinutes"
                                         Label="Earliest Arrival (minutes)"
                                         HelperText="Minutes into the raid before the train can first arrive."
                                         Variant="Variant.Outlined"
                                         Min="0" Step="1" />
                        <MudNumericField @bind-Value="Config.TrainSchedule.Static.ArriveLatestMinutes"
                                         Label="Latest Arrival (minutes)"
                                         HelperText="Minutes into the raid by which the train must arrive."
                                         Variant="Variant.Outlined"
                                         Min="0" Step="1" />
                        <MudNumericField @bind-Value="Config.TrainSchedule.Static.TrainWaitSeconds"
                                         Label="Train Wait (seconds)"
                                         HelperText="Seconds the train waits at the station before departing."
                                         Variant="Variant.Outlined"
                                         Min="0" Step="10" />
                    }
                </MudStack>
            </MudExpansionPanel>

        </MudExpansionPanels>
    </MudItem>
</MudGrid>

@code {
    private ModConfig Config => ConfigService.Config;
}
